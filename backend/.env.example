# Skopiuj do .env i uzupelnij sekrety.
NODE_ENV=development
PORT=4000

# "db" to nazwa uslugi Postgres w docker-compose.
DATABASE_URL=postgres://drink:drink@db:5432/drink_delivery

# Lista dozwolonych origin-ow (frontend). Wartosci rozdziel przecinkami, bez spacji.
# Bez wpisywania rekomenduje sie dodac adres komputera w LAN:
#   http://<IP_KOMPUTERA>:5173
# LAN (192.168.x.x / 10.x.x.x / 172.16-31.x.x) jest i tak akceptowany przez regex.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Sekrety JWT — w produkcji wygeneruj losowe (np. `openssl rand -hex 48`).
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
